---
import type { HTMLAttributes } from "astro/types";

type ButtonVariant = "default" | "outline" | "secondary" | "ghost" | "link";
type ButtonSize = "default" | "sm" | "lg" | "icon" | "icon-sm" | "icon-lg";

interface ButtonProps extends HTMLAttributes<"button"> {
  variant?: ButtonVariant;
  size?: ButtonSize;
  type?: "button" | "submit" | "reset";
  disabled?: boolean;
  class?: string;
}

const {
  variant = "default",
  size = "default",
  type = "button",
  disabled = false,
  class: className,
  ...rest
} = Astro.props as ButtonProps;
---

<button
  type={type}
  disabled={disabled}
  class:list={[
    "inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium leading-none transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/50 disabled:pointer-events-none disabled:opacity-50",
    {
      "text-xs px-3 py-1.5": size === "sm",
      "text-sm px-4 py-2": size === "default",
      "text-base px-6 py-3": size === "lg",
      "size-8 p-0 shrink-0 [&>svg]:size-4": size === "icon-sm",
      "size-10 p-0 shrink-0 [&>svg]:size-5": size === "icon",
      "size-14 p-0 shrink-0 [&>svg]:size-6": size === "icon-lg",
    },
    {
      "bg-foreground-0 text-background-0 hover:bg-background-0 hover:text-foreground-0 border border-foreground-0":
        variant === "default",
      "border border-border bg-transparent hover:bg-background-2 hover:text-accent":
        variant === "secondary",
      "border border-border bg-transparent hover:bg-none hover:text-accent":
        variant === "outline",
      "bg-transparent hover:bg-background-2 hover:text-accent":
        variant === "ghost",
      "text-accent underline-offset-4 hover:underline bg-transparent":
        variant === "link",
    },
    className,
  ]}
  {...rest}
>
  <slot />
</button>
