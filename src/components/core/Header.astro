---
// Header Component - Navigation and branding
import { navItems } from "@data/config";
import { Icon } from "astro-icon/components";
import MobileMenuPanel from "@/components/core/MobileMenuPanel.astro";
import MobileMenuToggle from "@/components/core/MobileMenuToggle.astro";
import Button from "@/components/ui/Button.astro";
---

<header
  class="border-border sticky top-0 z-50 flex h-24 items-center justify-center border-b bg-black px-4 py-12 md:px-12"
>
  <nav class="mx-auto w-full max-w-7xl">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <a href="/">
        <Button size="icon-sm" variant="default">
          <Icon name="lightning" />
        </Button>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden items-center gap-4 md:flex">
        {
          navItems
            .filter((item) => !item.special)
            .map((item) => (
              <a
                href={item.href}
                target={item.blank ? "_blank" : undefined}
                rel={item.blank ? "noopener noreferrer" : undefined}
              >
                <Button variant="ghost" size="sm">
                  {item.label}
                </Button>
              </a>
            ))
        }
      </div>

      <!-- Desktop CTA Button -->
      <a href="/contact/" class="hidden md:block">
        <Button size="sm" class="uppercase">GET IN TOUCH</Button>
      </a>

      <!-- Mobile Menu Toggle -->
      <MobileMenuToggle />
    </div>
  </nav>
</header>

<!-- Mobile Menu Panel -->
<MobileMenuPanel navItems={navItems.filter((item) => !item.special)} />
