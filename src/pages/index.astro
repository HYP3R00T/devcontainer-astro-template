---
import BaseLayout from '@/layouts/BaseLayout.astro'
---

<BaseLayout>
  <section
    class="stripe-pattern-dense relative flex h-screen items-center justify-center px-4 py-12 md:px-12"
  >
    <div class="mx-auto w-full max-w-2xl">
      <div class="space-y-12 text-center">
        <!-- Large 404 display -->
        <div class="relative">
          <div
            class="text-foreground-1 md:text-48 font-display text-9xl leading-none font-black tracking-tighter select-none"
          >
            404
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
