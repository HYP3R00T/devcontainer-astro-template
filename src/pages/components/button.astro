---
import { Icon } from "astro-icon/components";
import ButtonComponent from "@/components/ui/Button.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

export const metadata = {
  title: "Button",
  description: "Core button variants and sizes.",
  category: "ui",
  order: 1,
};

const variantOptions = ["default", "secondary", "outline", "ghost", "link"];

const textSizes = ["lg", "default", "sm"];
const iconSizes = ["icon-lg", "icon", "icon-sm"];
---

<BaseLayout
  title={`${metadata.title} - Components`}
  description={metadata.description}
>
  <section
    class="relative flex items-center justify-center bg-black px-4 py-12 md:px-12"
  >
    <div class="mx-auto w-full max-w-7xl">
      <header>
        <h1
          class="text-foreground-0 text-4xl font-extrabold uppercase"
          style="font-family: 'Space Grotesk', sans-serif;"
        >
          {metadata.title}
        </h1>
      </header>

      <section class="space-y-4">
        <h2 class="text-foreground-1 text-sm tracking-wide uppercase">
          Variants
        </h2>
        <div class="flex flex-wrap gap-3">
          {
            variantOptions.map((variant) => (
              <ButtonComponent variant={variant}>{variant}</ButtonComponent>
            ))
          }
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-foreground-1 text-sm tracking-wide uppercase">
          Text Sizes
        </h2>
        <div class="flex flex-wrap items-start gap-3">
          {
            textSizes.map((size) => (
              <ButtonComponent size={size}>{size}</ButtonComponent>
            ))
          }
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-foreground-1 text-sm tracking-wide uppercase">
          Icon Sizes
        </h2>
        <div class="flex flex-wrap items-start gap-6">
          {
            iconSizes.map((size) => (
              <div class="flex flex-col items-center gap-2">
                <span class="text-foreground-2 text-xs tracking-wide uppercase">
                  {size}
                </span>
                <ButtonComponent as="div" variant="outline" size={size}>
                  <Icon name="github" class="text-foreground-0" />
                </ButtonComponent>
              </div>
            ))
          }
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-foreground-1 text-sm tracking-wide uppercase">
          States
        </h2>
        <div class="flex flex-wrap gap-3">
          <ButtonComponent>Default</ButtonComponent>
          <ButtonComponent disabled>Disabled</ButtonComponent>
        </div>
      </section>
    </div>
  </section>
</BaseLayout>
