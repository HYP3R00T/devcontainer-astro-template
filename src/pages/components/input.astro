---
import InputComponent from "@/components/ui/Input.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

export const metadata = {
  title: "Input",
  description: "Simplified form inputs.",
  category: "form",
  order: 3,
};

const types = ["text", "email", "password", "number", "url"];
---

<BaseLayout
  title={`${metadata.title} - Components`}
  description={metadata.description}
>
  <section
    class="relative flex items-center justify-center bg-black px-4 py-12 md:px-12"
  >
    <div class="mx-auto w-full max-w-7xl">
      <h1
        class="text-foreground-0 text-4xl font-extrabold uppercase"
        style="font-family: 'Space Grotesk', sans-serif;"
      >
        {metadata.title}
      </h1>

      <section class="space-y-4">
        <h2 class="text-foreground-1 text-sm tracking-wide uppercase">Types</h2>
        <div class="space-y-3">
          {
            types.map((item) => (
              <div class="flex flex-col gap-2">
                <span class="text-foreground-2 text-xs tracking-wide uppercase">
                  {item}
                </span>
                <InputComponent type={item} placeholder={`Enter ${item}`} />
              </div>
            ))
          }
        </div>
      </section>

      <section class="space-y-4">
        <h2 class="text-foreground-1 text-sm tracking-wide uppercase">
          States
        </h2>
        <div class="space-y-3">
          <div class="flex flex-col gap-2">
            <span class="text-foreground-2 text-xs tracking-wide uppercase"
              >Default</span
            >
            <InputComponent placeholder="Default" />
          </div>
          <div class="flex flex-col gap-2">
            <span class="text-foreground-2 text-xs tracking-wide uppercase"
              >Disabled</span
            >
            <InputComponent placeholder="Disabled" disabled />
          </div>
        </div>
      </section>
    </div>
  </section>
</BaseLayout>
